# Copy this file to secrets.yaml and fill in your values.
# secrets.yaml is git-ignored and must never be committed.

wifi_ssid: "YourWiFiSSID"
wifi_password: "YourWiFiPassword"
wifi_fallback_password: "FallbackAPPassword"
encryption_key: "REPLACE_WITH_32_BYTE_BASE64_KEY"
ota_password: "REPLACE_WITH_OTA_PASSWORD"
